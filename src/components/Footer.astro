---
import { site } from '../config/site';

const { paths, linkedin } = site;
---

<footer class="site-footer">
  <div class="wrap-wide">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/assets/haidi.png" alt="Haidi" width="100" height="26" loading="lazy" />
        <p>
          A supply chain planning platform built around your team — clearer demand, inventory, and
          supply decisions, with full transparency into the reasoning behind them.
        </p>
      </div>
      <div class="footer-col">
        <h5>Product</h5>
        <a href={paths.product}>Overview</a>
        <a href={`${paths.product}#scenario`}>Scenario Testing</a>
        <a href={`${paths.product}#demand-review`}>Demand Review</a>
        <a href={`${paths.product}#forecast-lab`}>Forecast Lab</a>
        <a href={`${paths.product}#haidi-gen`}>Haidi Gen</a>
      </div>
      <div class="footer-col">
        <h5>Use Cases</h5>
        <a href={`${paths.usecases}#industries`}>Pharma</a>
        <a href={`${paths.usecases}#industries`}>Manufacturing</a>
        <a href={`${paths.usecases}#industries`}>Energy</a>
        <a href={`${paths.usecases}#industries`}>FMCG</a>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <a href={paths.about}>About Haidi</a>
        <a href="https://www.ibpready.com/" target="_blank" rel="noopener noreferrer">IBP Ready</a>
        <a href={paths.contact}>Contact</a>
        <a href={linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Haidi · Built by IBP Ready, Switzerland</span>
      <span style="display:flex;gap:22px">
        <a href={paths.privacy}>Privacy</a>
        <a href={paths.terms}>Terms</a>
        <a href={paths.security}>Security</a>
        <a href="/preloader-preview">Preloader</a>
      </span>
    </div>
  </div>
</footer>
