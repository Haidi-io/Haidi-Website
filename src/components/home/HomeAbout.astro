---
import HomePanel from './HomePanel.astro';
import SectionRule from './SectionRule.astro';
---

<HomePanel id="about" screenLabel="About">
  <SectionRule num="04" left="Who is behind Haidi" right="IBP Ready · Switzerland" />
  <div class="about-grid about-grid--panel">
    <div class="about-copy reveal">
      <span class="ap-flag"><span></span> IBP Ready · Switzerland · Founded 2018</span>
      <h2 class="display">Built by a consulting team that lives in supply chain planning.</h2>
      <p>Haidi is built by IBP Ready, a Switzerland-based supply chain consulting company trusted by global enterprises.</p>
      <a class="link-arrow" href="/about#ibp">Meet IBP Ready
        <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <div class="about-panel reveal" data-delay="1">
      <div class="about-panel-inner">
        <div class="ap-row">
          <div class="ap-stat"><span data-count="60" data-suffix="+">0</span></div>
          <div class="ap-desc">years of combined supply chain planning experience</div>
        </div>
        <div class="ap-row">
          <div class="ap-stat"><span data-count="2018">0</span></div>
          <div class="ap-desc">founded as a specialist supply chain consultancy</div>
        </div>
        <div class="ap-row">
          <div class="ap-stat">Global</div>
          <div class="ap-desc">enterprise planning environments worldwide</div>
        </div>
      </div>
    </div>
  </div>
</HomePanel>
