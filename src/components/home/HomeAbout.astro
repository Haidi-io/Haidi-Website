---
import HomePanel from './HomePanel.astro';
import SectionRule from './SectionRule.astro';
---

<HomePanel id="about" screenLabel="About">
  <SectionRule num="05" left="Who is behind Haidi" right="IBP Ready · Switzerland" />
  <div class="about-grid about-grid--panel">
    <div class="about-copy reveal">
      <h2 class="display">Born in Switzerland.<br />Built by a <span class="accent">worldwide team</span> for supply chains globally.</h2>
      <p>Haidi is built by IBP Ready, a Switzerland-based supply chain consultancy. We don't theorise about planning – we've done it, across every scale of business.</p>
      <a class="link-arrow" href="https://www.ibpready.com/" target="_blank" rel="noopener">Meet IBP Ready
        <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <div class="about-panel reveal" data-delay="1">
      <div class="about-panel-inner">
        <div class="ap-row">
          <div class="ap-stat"><span data-count="80" data-suffix="+">0</span></div>
          <div class="ap-desc">years of combined supply chain planning experience</div>
        </div>
        <div class="ap-row">
          <div class="ap-stat"><span data-count="2018">0</span></div>
          <div class="ap-desc">the year we started – focused only on supply chain planning ever since</div>
        </div>
        <div class="ap-row">
          <div class="ap-stat"><span data-count="40" data-suffix="+">0</span></div>
          <div class="ap-desc">multinationals and SMEs – from 50-person firms to enterprises running hundreds of thousands of SKUs</div>
        </div>
      </div>
    </div>
  </div>
</HomePanel>
