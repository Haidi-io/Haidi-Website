---

<section class="hero home-panel" id="main" data-hero-root data-scroll-panel data-screen-label="Home">
  <div class="hero-canvas-host">
    <canvas class="hero-canvas" aria-hidden="true"></canvas>
  </div>

  <div class="hero-content home-panel__inner">
    <div class="hero-v hero-v--workspace">
      <div class="wrap">
        <div class="hero-text">
          <span class="eyebrow eyebrow--wrap">Supply chain planning</span>
          <h1 class="display">Demand and inventory planning you can explain – <span class="accent">set up in under 2 hours</span></h1>
          <p class="hero-sub">From demand signal to inventory decision – with scenario testing built in. Clear enough to explain to your CFO. Fast enough to be useful today.</p>
          <div class="hero-cta">
            <a class="btn btn-primary btn-lg" href="/contact">Prepare to launch</a>
            <a class="btn btn-secondary btn-lg" href="/product-overview">Explore the product
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <p class="hero-note">Built by supply chain practitioners · Forecasting you can explain</p>
        </div>
      </div>
    </div>

    <div class="hero-v hero-v--minimal">
      <div class="wrap">
        <div class="hero-text">
          <span class="eyebrow">Haidi</span>
          <h1 class="display">Demand and inventory planning you can explain – <span class="accent">set up in under 2 hours</span></h1>
          <p class="hero-sub">From demand signal to inventory decision – with scenario testing built in. Clear enough to explain to your CFO. Fast enough to be useful today.</p>
          <div class="hero-cta">
            <a class="btn btn-primary btn-lg" href="/contact">Prepare to launch</a>
            <a class="btn btn-secondary btn-lg" href="/product-overview">Explore the product
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-v hero-v--tagline">
      <div class="wrap">
        <div class="hero-text">
          <span class="eyebrow eyebrow--wrap">Supply chain planning</span>
          <h1 class="display">Demand and inventory planning you can explain – <span class="accent">set up in under 2 hours</span></h1>
          <div class="hero-cta">
            <a class="btn btn-primary btn-lg" href="/contact">Prepare to launch</a>
            <a class="btn btn-secondary btn-lg" href="/product-overview">Explore the product
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll">Scroll</div>
</section>

<script>
  function bootHero() {
    if (document.querySelector('script[data-haidi-hero]')) return;
    const s = document.createElement('script');
    s.src = '/assets/haidi-hero.js';
    s.dataset.haidiHero = '';
    document.body.appendChild(s);
  }

  const hero = document.querySelector('.hero');
  if (hero && 'IntersectionObserver' in window) {
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) {
          bootHero();
          obs.disconnect();
        }
      },
      { rootMargin: '120px' },
    );
    obs.observe(hero);
  } else {
    bootHero();
  }
</script>
