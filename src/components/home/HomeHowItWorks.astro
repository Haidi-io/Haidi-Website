---
import HomePanel from './HomePanel.astro';
import SectionRule from './SectionRule.astro';
---

<HomePanel id="how" screenLabel="How it works">
  <SectionRule num="03" left="How it works" right="From setup to first forecast" />
  <div class="collab-top">
    <div class="section-head reveal" style="margin:0">
      <h2 class="display">Onboarding that fits<br /><span class="accent">around your team.</span></h2>
      <p>From workspace setup to a first forecast — focused collaboration, not a long enterprise rollout.</p>
    </div>
    <div class="collab-time reveal" data-delay="1">
      <div class="ct-num"><span class="accent">2–3</span> hrs</div>
      <div class="ct-lbl">Focused collaboration to a first forecast</div>
    </div>
  </div>
</HomePanel>

<HomePanel screenLabel="How it works">
  <div class="flow flow--panel reveal">
    <div class="flow-step">
      <div class="fdot"><svg viewBox="0 0 24 24" fill="none" width="20" height="20"><rect x="4" y="5" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M4 9h16M9 5v14" stroke="currentColor" stroke-width="1.7"/></svg></div>
      <span class="fnum">01</span><h4>Define the scope</h4><p>Agree the planning scope and categories that matter most.</p>
    </div>
    <div class="flow-step">
      <div class="fdot"><svg viewBox="0 0 24 24" fill="none" width="20" height="20"><ellipse cx="12" cy="6" rx="7" ry="2.6" stroke="currentColor" stroke-width="1.7"/><path d="M5 6v12c0 1.4 3.1 2.6 7 2.6s7-1.2 7-2.6V6" stroke="currentColor" stroke-width="1.7"/></svg></div>
      <span class="fnum">02</span><h4>Connect the data</h4><p>Share or connect demand history and business inputs.</p>
    </div>
    <div class="flow-step">
      <div class="fdot"><svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
      <span class="fnum">03</span><h4>Review quality &amp; drivers</h4><p>Check data quality and confirm demand drivers.</p>
    </div>
    <div class="flow-step">
      <div class="fdot"><svg viewBox="0 0 24 24" fill="none" width="20" height="20"><path d="M4 18l5-7 4 3 7-9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
      <span class="fnum">04</span><h4>Generate the forecast</h4><p>Produce a first forecast you can read and compare.</p>
    </div>
    <div class="flow-step">
      <div class="fdot"><svg viewBox="0 0 24 24" fill="none" width="20" height="20"><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.7"/><circle cx="16" cy="14" r="3" stroke="currentColor" stroke-width="1.7"/><path d="M11 10l3 2" stroke="currentColor" stroke-width="1.7"/></svg></div>
      <span class="fnum">05</span><h4>Review &amp; decide</h4><p>Adjust assumptions and collaborate on the decision.</p>
    </div>
  </div>
  <p class="collab-close reveal">Haidi gives planners a clearer system — so time goes into decisions, not assembling data.</p>
</HomePanel>
