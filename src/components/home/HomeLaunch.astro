---
import HomePanel from './HomePanel.astro';
---

<HomePanel id="launch" screenLabel="Launch CTA" class="launch">
  <div class="launch-glow"></div>
  <div class="launch__content reveal">
    <span class="eyebrow eyebrow--wrap" style="justify-content:center">Prepare to launch</span>
    <h2 class="display" style="margin-top:20px">Let's find your <span class="accent">starting point</span></h2>
    <p>Leave your details and a quick note about your planning process — we'll come back with the most useful next step.</p>
    <div class="launch-chips">
      <span>Tailored demo</span><span>Focused discussion</span><span>Relevant case study</span>
    </div>
    <div class="hero-cta">
      <a class="btn btn-primary btn-lg" href="/contact">Prepare to launch</a>
      <a class="btn btn-secondary btn-lg" href="/product-overview">Explore the product
        <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</HomePanel>
