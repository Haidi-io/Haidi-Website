---
import HomePanel from './HomePanel.astro';
---

<HomePanel id="launch" screenLabel="Launch CTA" class="launch">
  <div class="launch-glow"></div>
  <div class="launch__content reveal">
    <span class="eyebrow eyebrow--wrap" style="justify-content:center">Prepare to launch</span>
    <h2 class="display" style="margin-top:20px">Prepare to launch Haidi.</h2>
    <p>Answer a few questions about your planning situation — we'll recommend a tailored demo or relevant case study.</p>
    <div class="launch-chips">
      <span>Your industry</span><span>Your planning process</span><span>Current tools</span><span>Data readiness</span><span>Main challenge</span>
    </div>
    <div class="hero-cta">
      <a class="btn btn-primary btn-lg" href="/contact">Prepare to launch</a>
      <a class="btn btn-secondary btn-lg" href="/product-overview">Explore the product</a>
    </div>
  </div>
</HomePanel>
