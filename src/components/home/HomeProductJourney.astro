---
import HomePanel from './HomePanel.astro';
import ProductFrame from './ProductFrame.astro';

const steps = [
  { id: 'drivers', num: '01', title: 'Demand Drivers', desc: 'Signals flow in from markets, promotions, and commercial activity.', mock: 'drivers', url: 'app.haidi.io / drivers' },
  { id: 'experiments', num: '02', title: 'Forecast Lab', desc: 'The forecast line branches into experiments your team can compare.', mock: 'experiments', url: 'app.haidi.io / forecast-lab' },
  { id: 'review', num: '03', title: 'Demand Review', desc: 'Review exceptions, assumptions, and decisions in one workspace.', mock: 'review', url: 'app.haidi.io / demand-review' },
  { id: 'scenario', num: '04', title: 'Scenario Testing', desc: 'Test alternatives before the plan becomes a commitment.', mock: 'scenario', url: 'app.haidi.io / scenarios' },
];
---

<div data-product-journey>
  <HomePanel screenLabel="Product journey">
    <span class="eyebrow">From signal to decision</span>
    <h2 class="display journey-intro__title">The forecast line leads<br /><span class="accent">into the product.</span></h2>
    <p class="journey-intro__sub">What you see in the hero — demand signals converging on a forecast — is the same journey inside Haidi.</p>
  </HomePanel>

  {steps.map((step) => (
    <HomePanel journeyStep={step.id} screenLabel={`Journey · ${step.title}`}>
      <div class="journey-panel">
        <div class="journey-panel__copy">
          <div class="product-journey__step is-active" data-journey-step={step.id}>
            <span class="product-journey__step-num">{step.num}</span>
            <div>
              <h4>{step.title}</h4>
              <p>{step.desc}</p>
            </div>
          </div>
        </div>
        <div class="journey-panel__mock">
          <div class="product-journey__mock-panel is-active" data-journey-panel={step.id}>
            <ProductFrame mock={step.mock} url={step.url} loop />
          </div>
        </div>
      </div>
    </HomePanel>
  ))}
</div>
