---
import HomePanel from './HomePanel.astro';
---

<div data-product-journey>
  <HomePanel screenLabel="Why Haidi">
    <div class="why3 reveal">
      <div class="why3-col">
        <span class="why3-num">01</span>
        <h3>From signal to decision in one workspace</h3>
        <p>Forecast demand, manage inventory risk, and test scenarios without switching tools or rebuilding spreadsheets. The full planning cycle, connected.</p>
      </div>
      <div class="why3-col">
        <span class="why3-num">02</span>
        <h3>No inflated projects. No slide decks.</h3>
        <p>Built from the trenches by experienced supply chain practitioners. You like it, you continue. You hate it, you walk away. No 2-year lock-in, no contracts held together by the fear of losing what you've already paid for.</p>
      </div>
      <div class="why3-col">
        <span class="why3-num">03</span>
        <h3>Explainable forecasts. Running before end of day.</h3>
        <p>Every forecast shows why it was chosen. Every inventory signal links back to the demand assumption behind it. Set up in under 2 hours — no specialists required.</p>
      </div>
    </div>
  </HomePanel>
</div>
