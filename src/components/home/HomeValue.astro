---
import HomePanel from './HomePanel.astro';
import SectionRule from './SectionRule.astro';
---

<HomePanel id="value" screenLabel="Value">
  <SectionRule num="01" left="Why teams choose Haidi" right="Planning, made practical" />
  <div class="section-head reveal">
    <h2 class="display">A planning platform shaped by<br /><span class="accent">how planners actually work.</span></h2>
    <p>Haidi brings demand and inventory planning into one practical workspace, with modern capabilities for scenario testing, assumption review, and decision-making.</p>
  </div>
  <div class="value value--panel">
    <div class="value-col reveal" data-delay="1">
      <div class="vcue"><svg viewBox="0 0 80 40" fill="none" width="80" height="40"><path d="M44 4 L28 22 L39 22 L36 36 L52 17 L41 17 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/></svg></div>
      <h3>Live before the end of day</h3>
    </div>
    <div class="value-col reveal" data-delay="2">
      <div class="vcue"><svg viewBox="0 0 80 40" fill="none" width="80" height="40"><circle cx="14" cy="20" r="6" stroke="currentColor" stroke-width="2"/><circle cx="40" cy="12" r="6" stroke="currentColor" stroke-width="2"/><circle cx="40" cy="28" r="6" stroke="currentColor" stroke-width="2"/><circle cx="66" cy="20" r="6" stroke="currentColor" stroke-width="2"/><path d="M20 20h14M46 13l14 5M46 27l14-5" stroke="currentColor" stroke-width="1.5"/></svg></div>
      <h3>The whole planning cycle, one workspace</h3>
    </div>
    <div class="value-col reveal" data-delay="3">
      <div class="vcue"><svg viewBox="0 0 80 40" fill="none" width="80" height="40"><path d="M24 6 H56 A4 4 0 0 1 60 10 V24 A4 4 0 0 1 56 28 H40 L32 35 L33 28 H24 A4 4 0 0 1 20 24 V10 A4 4 0 0 1 24 6 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M29 21 L35 15 L40 18 L47 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
      <h3>Forecasts that explain themselves</h3>
    </div>
    <div class="value-col reveal" data-delay="4">
      <div class="vcue"><svg viewBox="0 0 80 40" fill="none" width="80" height="40"><rect x="30" y="18" width="20" height="16" rx="2.5" stroke="currentColor" stroke-width="2"/><path d="M34 18 v-4 a6 6 0 0 1 11.4 -2.6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="40" cy="25" r="1.8" fill="currentColor"/><path d="M40 26.8 v3.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></div>
      <h3>No contracts, no lock-in</h3>
    </div>
  </div>
</HomePanel>
