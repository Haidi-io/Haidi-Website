---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
import ContactModal from '../components/ContactModal.astro';
import { site } from '../config/site';
import type { NavKey } from '../config/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  nav?: NavKey;
  screenLabel?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
  heroVariants?: boolean;
  scripts?: string[];
}

const {
  title,
  description = '',
  canonical = '',
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonical,
  nav = '',
  screenLabel = '',
  noindex = false,
  jsonLd,
  heroVariants = false,
  scripts = ['haidi-site.js'],
} = Astro.props;
---

<!doctype html>
<html lang="en" data-font="inter" data-canvas="graphite">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={ogTitle} />
    {ogDescription && <meta property="og:description" content={ogDescription} />}
    <meta property="og:type" content="website" />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta name="twitter:card" content="summary" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <script is:inline>window.__HAIDI_GSAP__ = true;</script>
    {/* Theme is applied inline (before paint) to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        var KEY = 'haidi-theme';
        // An explicitly chosen theme (via the toggle) is the only thing that
        // overrides the OS preference. No saved value => follow the system.
        function stored() {
          try { var s = localStorage.getItem(KEY); if (s === 'light' || s === 'dark') return s; } catch (e) {}
          return null;
        }
        function system() {
          return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        function label(theme) {
          return 'Switch to ' + (theme === 'dark' ? 'light' : 'dark') + ' theme';
        }
        function apply(theme, persist) {
          document.documentElement.setAttribute('data-theme', theme);
          if (persist) { try { localStorage.setItem(KEY, theme); } catch (e) {} }
          document.querySelectorAll('.theme-toggle').forEach(function (btn) {
            btn.setAttribute('aria-label', label(theme));
            btn.setAttribute('title', label(theme));
          });
        }
        // Initial paint: OS preference unless the visitor previously chose one.
        apply(stored() || system(), false);

        // Follow live OS theme changes while the visitor hasn't picked a theme.
        try {
          var mq = window.matchMedia('(prefers-color-scheme: dark)');
          var onSystem = function () { if (!stored()) apply(system(), false); };
          if (mq.addEventListener) mq.addEventListener('change', onSystem);
          else if (mq.addListener) mq.addListener(onSystem);
        } catch (e) {}

        function initToggle() {
          document.querySelectorAll('.theme-toggle').forEach(function (btn) {
            if (btn.__themeBound) return;
            btn.__themeBound = true;
            btn.addEventListener('click', function () {
              var cur = document.documentElement.getAttribute('data-theme') || 'dark';
              apply(cur === 'dark' ? 'light' : 'dark', true); // explicit choice – persist
            });
          });
        }
        window.haidiSetTheme = function (theme) { apply(theme, true); };
        window.haidiInitThemeToggle = initToggle;
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initToggle);
        else initToggle();
      })();
    </script>
    {heroVariants && <script is:inline src="/assets/hero-variants.js"></script>}
    <link rel="stylesheet" href="/assets/haidi.css" />
    <script is:inline define:vars={{ siteConfig: site }}>
      window.HAIDI_SITE = siteConfig;
    </script>
  </head>
  <body data-nav={nav} data-screen-label={screenLabel}>
    <Preloader />
    <Header active={nav} />
    <slot />
    <Footer />
    <ContactModal />
    <script>
      // The custom cursor (gsap core only) runs on every page.
      import { initHaidiCursor } from '../lib/haidi-cursor';
      initHaidiCursor();

      // The scroll-animation engine (gsap + ScrollTrigger) is loaded only when a
      // page actually has animated elements – legal pages skip it entirely.
      if (document.querySelector('.reveal, [data-hero-root], [data-scroll-panel]')) {
        import('../lib/haidi-gsap').then(({ initHaidiGsap }) => initHaidiGsap());
      }

      // Hero 3D (three.js) – loaded only when a WebGL hero mode is active, so
      // default visitors on the 2D 'canvas' mode never download three.js.
      const HERO_3D = ['globe', 'terrain', 'field3d', 'network3d'];
      function maybeLoadHero3D() {
        const a = document.documentElement.getAttribute('data-hero-animation');
        if (a && HERO_3D.includes(a)) {
          import('../lib/haidi-hero-3d').then(({ initHaidiHero3D }) => initHaidiHero3D());
          return true;
        }
        return false;
      }
      if (document.querySelector('.hero-canvas-host')) {
        if (!maybeLoadHero3D()) {
          window.addEventListener('haidi:hero-variant', function onVariant() {
            if (maybeLoadHero3D()) window.removeEventListener('haidi:hero-variant', onVariant);
          });
        }
      }
    </script>
    {scripts.map((src) => (
      <script is:inline src={`/assets/${src}`}></script>
    ))}
    {/* Mock UI (~18KB) is below the fold – keep it out of the initial render path and
        hydrate it when a mock container nears the viewport, with an idle fallback so it
        always loads even inside the home page's custom scroll-snap section. */}
    <script is:inline>
      (function () {
        var mocks = document.querySelectorAll('[data-mock], [data-frag]');
        if (!mocks.length) return;
        var loaded = false;
        var io;
        function load() {
          if (loaded) return;
          loaded = true;
          if (io) io.disconnect();
          var s = document.createElement('script');
          s.src = '/assets/haidi-mocks.js';
          s.dataset.haidiMocks = '';
          document.body.appendChild(s);
        }
        if ('IntersectionObserver' in window) {
          io = new IntersectionObserver(function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) { load(); break; }
            }
          }, { rootMargin: '300px' });
          mocks.forEach(function (el) { io.observe(el); });
        } else {
          load();
        }
        var idle = window.requestIdleCallback || function (cb) { return setTimeout(cb, 1500); };
        idle(load);
      })();
    </script>
  </body>
</html>
