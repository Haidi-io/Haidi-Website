---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Haidi — Prepare to launch" description="Tell us about your planning process and we'll recommend the best next step — a tailored demo, case study, or focused discussion." canonical="https://haidi.io/contact" ogTitle="Haidi — Prepare to launch" ogDescription="Answer a few questions about your planning situation and the Haidi team will recommend the best next step." ogUrl="https://haidi.io/contact" screenLabel="Contact" scripts={['haidi-site.js', 'contact-form.js', 'haidi-tweaks.js']}>
  <style is:global>
/* ── HERO ─────────────────────────────────────────────── */
  .ct-hero { padding: 64px 0 50px; position: relative; }
  .ct-hero .wrap-wide { max-width: 1180px; }
  .ct-hero h1 { font-size: clamp(36px, 4.6vw, 60px); line-height: 1.02; margin: 22px 0 22px; max-width: 16ch; }
  .ct-hero p { font-size: 18px; color: var(--text-body); max-width: 620px; text-wrap: pretty; }
  .ct-next { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
  .ct-next span { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-body); border: 1px solid var(--line); border-radius: 999px; padding: 8px 15px; background: rgba(255,255,255,0.02); }
  .ct-next span::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--teal); }

  /* ── LAYOUT ───────────────────────────────────────────── */
  .ct-grid { display: grid; grid-template-columns: 1.5fr 0.9fr; gap: 34px; align-items: start; max-width: 1180px; }
  @media (max-width: 980px) { .ct-grid { grid-template-columns: 1fr; } }

  /* ── FORM CARD ────────────────────────────────────────── */
  .cf { border: 1px solid var(--line-2); border-radius: 16px; background: var(--bg-1); overflow: hidden; box-shadow: 0 50px 110px -50px rgba(0,0,0,0.9); }
  .cf-top { padding: 22px 30px 0; }
  .cf-progress { height: 3px; border-radius: 3px; background: rgba(255,255,255,0.08); overflow: hidden; }
  .cf-progress-fill { height: 100%; width: 0; background: var(--teal); border-radius: 3px; transition: width .5s var(--ease); }
  .cf-meta { display: flex; align-items: center; justify-content: space-between; margin-top: 14px; }
  .cf-meta .cf-step-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); }
  .cf-dots { display: flex; gap: 7px; }
  .cf-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.14); transition: background .3s, transform .3s; }
  .cf-dot.active { background: var(--teal); transform: scale(1.3); }
  .cf-dot.done { background: var(--teal-deep); }

  .cf-body { padding: 12px 30px 30px; }
  .cf-step { display: none; }
  .cf-step.on { display: block; animation: cfin .4s var(--ease); }
  @keyframes cfin { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) { .cf-step.on { animation: none; } }
  .cf-step-title { font-size: 22px; font-weight: 500; color: var(--text); letter-spacing: -0.02em; margin: 16px 0 4px; }
  .cf-step-sub { font-size: 14px; color: var(--text-muted); margin-bottom: 22px; }

  [data-row] { margin-bottom: 20px; }
  .cf-label { display: block; font-size: 13px; color: var(--text-body); margin-bottom: 9px; font-weight: 500; }
  .cf-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 540px) { .cf-grid2 { grid-template-columns: 1fr; } }
  .cf-input, .cf-area {
    width: 100%; font-family: inherit; font-size: 15px; color: var(--text);
    background: rgba(255,255,255,0.03); border: 1px solid var(--line-2); border-radius: 9px;
    padding: 12px 14px; transition: border-color .2s, background .2s;
  }
  .cf-input::placeholder, .cf-area::placeholder { color: var(--text-faint); }
  .cf-input:focus, .cf-area:focus { outline: none; border-color: var(--teal); background: rgba(71,185,187,0.06); }
  .cf-area { resize: vertical; min-height: 96px; line-height: 1.5; }
  .cf-chips { display: flex; flex-wrap: wrap; gap: 9px; }
  .cf-chip {
    font-family: inherit; font-size: 13.5px; color: var(--text-body); cursor: pointer;
    background: rgba(255,255,255,0.03); border: 1px solid var(--line-2); border-radius: 999px;
    padding: 9px 16px; transition: border-color .2s, color .2s, background .2s, transform .15s;
  }
  .cf-chip:hover { border-color: var(--teal); color: var(--text); }
  .cf-chip.on { background: var(--teal-16); border-color: var(--teal); color: var(--teal); }
  .cf-msg { display: block; font-size: 12px; color: var(--coral); margin-top: 8px; min-height: 0; }
  [data-row].cf-err .cf-input, [data-row].cf-err .cf-area { border-color: var(--coral); }

  .cf-foot { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-top: 28px; }
  .cf-foot .cf-spacer { margin-left: auto; }

  /* summary */
  .cf-summary { border: 1px solid var(--line); border-radius: 11px; overflow: hidden; margin: 6px 0 4px; }
  .cf-sum-row { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 14px; padding: 12px 16px; border-bottom: 1px solid var(--line); font-size: 13.5px; }
  .cf-sum-row:last-child { border-bottom: 0; }
  .cf-sum-k { color: var(--text-muted); }
  .cf-sum-v { color: var(--text); }

  /* done */
  .cf-done { display: none; padding: 56px 36px; text-align: center; }
  .cf-done.on { display: block; animation: cfin .5s var(--ease); }
  .cf-done .cf-check { width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; background: var(--teal-16); border: 1px solid rgba(71,185,187,0.4); color: var(--teal); }
  .cf-done h2 { font-size: 28px; font-weight: 500; margin-bottom: 14px; }
  .cf-done p { font-size: 15px; color: var(--text-body); max-width: 420px; margin: 0 auto 8px; text-wrap: pretty; }

  /* ── SIDEBAR ──────────────────────────────────────────── */
  .ct-side { display: flex; flex-direction: column; gap: 20px; position: sticky; top: 96px; }
  @media (max-width: 980px) { .ct-side { position: static; } }
  .side-card { border: 1px solid var(--line); border-radius: 14px; background: var(--bg-1); padding: 26px 26px; }
  .side-card h3 { font-size: 16px; font-weight: 500; margin-bottom: 16px; }
  .side-card .ap-flag { display: inline-flex; align-items: center; gap: 9px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 16px; }
  .side-card .ap-flag span { width: 16px; height: 11px; border-radius: 2px; background: linear-gradient(#D52B1E 0 45%, #fff 45% 55%, #D52B1E 55%); }
  .side-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  .side-list li { display: flex; gap: 12px; align-items: flex-start; font-size: 13.5px; color: var(--text-body); padding: 11px 0; border-top: 1px solid var(--line); }
  .side-list li:first-child { border-top: 0; }
  .side-list li svg { width: 16px; height: 16px; color: var(--teal); flex: 0 0 auto; margin-top: 2px; }
  .side-contact a { display: flex; align-items: center; gap: 11px; font-size: 14px; color: var(--text-body); padding: 11px 0; border-top: 1px solid var(--line); transition: color .2s; }
  .side-contact a:first-of-type { border-top: 0; }
  .side-contact a:hover { color: var(--teal); }
  .side-contact a svg { width: 17px; height: 17px; color: var(--teal); }

  /* ── WHAT HAPPENS NEXT ────────────────────────────────── */
  .next-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 52px; }
  .ns { border: 1px solid var(--line); border-radius: 12px; padding: 28px 26px; transition: border-color .3s, background .3s; }
  .ns:hover { border-color: rgba(71,185,187,0.4); background: var(--bg-1); }
  .ns .ns-num { font-family: var(--mono); font-size: 12px; letter-spacing: 0.18em; color: var(--teal); }
  .ns h4 { font-size: 17px; font-weight: 500; margin: 14px 0 10px; }
  .ns p { font-size: 14px; color: var(--text-muted); text-wrap: pretty; }
  @media (max-width: 800px) { .next-steps { grid-template-columns: 1fr; } }

  /* ── FINAL NOTE ───────────────────────────────────────── */
  .ct-note { text-align: center; max-width: 640px; margin: 0 auto; padding: 100px 0 40px; }
  .ct-note p { font-size: clamp(22px, 3vw, 32px); color: var(--text); font-weight: 500; letter-spacing: -0.02em; line-height: 1.25; text-wrap: pretty; }
  .ct-note .accent { color: var(--teal); }
  </style>

  <div set:html={`<!-- ============ HERO ============ -->
  <section class="ct-hero" id="main" data-screen-label="Contact hero">
    <div class="wrap-wide">
      <span class="eyebrow">Prepare to launch</span>
      <h1 class="display">Prepare to launch <span class="accent">Haidi.</span></h1>
      <p>Tell us a little about your planning process and what is currently getting in the way. We will review your situation and recommend the most useful next step.</p>
      <div class="ct-next">
        <span>A tailored product demonstration</span>
        <span>A focused planning discussion</span>
        <span>A relevant case study</span>
        <span>A data &amp; process readiness conversation</span>
      </div>
    </div>
  </section>

  <!-- ============ FORM + SIDEBAR ============ -->
  <section style="padding-bottom:30px" data-screen-label="Qualification form">
    <div class="wrap-wide ct-grid">

      <!-- FORM -->
      <div class="cf" data-cform>
        <div data-card>
          <div class="cf-top">
            <div class="cf-progress"><div class="cf-progress-fill" data-progress-fill></div></div>
            <div class="cf-meta">
              <span class="cf-step-label" data-progress-label>Step 1 of 5</span>
              <div class="cf-dots" data-dots></div>
            </div>
          </div>
          <div class="cf-body">

            <!-- STEP 1 -->
            <div class="cf-step" data-step>
              <div class="cf-step-title">About your company</div>
              <div class="cf-step-sub">A few details so we can route your enquiry to the right person.</div>
              <div class="cf-grid2">
                <div data-row><label class="cf-label">Name</label><input class="cf-input" data-field="name" data-required="text" placeholder="Your full name" /><span class="cf-msg" data-msg></span></div>
                <div data-row><label class="cf-label">Work email</label><input class="cf-input" type="email" data-field="email" data-required="email" placeholder="you@company.com" /><span class="cf-msg" data-msg></span></div>
                <div data-row><label class="cf-label">Company</label><input class="cf-input" data-field="company" data-required="text" placeholder="Company name" /><span class="cf-msg" data-msg></span></div>
                <div data-row><label class="cf-label">Job title</label><input class="cf-input" data-field="title" placeholder="e.g. Demand Planning Lead" /><span class="cf-msg" data-msg></span></div>
                <div data-row><label class="cf-label">Country or region</label><input class="cf-input" data-field="country" placeholder="e.g. Switzerland" /><span class="cf-msg" data-msg></span></div>
              </div>
              <div data-row style="margin-top:4px">
                <label class="cf-label">Industry</label>
                <div class="cf-chips" data-chips data-field="industry" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Pharma" aria-pressed="false">Pharma</button>
                  <button type="button" class="cf-chip" data-value="Manufacturing" aria-pressed="false">Manufacturing</button>
                  <button type="button" class="cf-chip" data-value="Energy" aria-pressed="false">Energy</button>
                  <button type="button" class="cf-chip" data-value="FMCG" aria-pressed="false">FMCG</button>
                  <button type="button" class="cf-chip" data-value="Retail" aria-pressed="false">Retail</button>
                  <button type="button" class="cf-chip" data-value="Consumer goods" aria-pressed="false">Consumer goods</button>
                  <button type="button" class="cf-chip" data-value="Other" aria-pressed="false">Other</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div class="cf-foot"><span class="cf-spacer"></span><button type="button" class="btn btn-primary" data-next>Continue</button></div>
            </div>

            <!-- STEP 2 -->
            <div class="cf-step" data-step>
              <div class="cf-step-title">Your planning environment</div>
              <div class="cf-step-sub">How planning works for your team today.</div>
              <div data-row>
                <label class="cf-label">Which planning areas are most relevant?</label>
                <div class="cf-chips" data-chips data-multi data-field="planningAreas" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Demand planning" aria-pressed="false">Demand planning</button>
                  <button type="button" class="cf-chip" data-value="Forecasting" aria-pressed="false">Forecasting</button>
                  <button type="button" class="cf-chip" data-value="Inventory planning" aria-pressed="false">Inventory planning</button>
                  <button type="button" class="cf-chip" data-value="Scenario planning" aria-pressed="false">Scenario planning</button>
                  <button type="button" class="cf-chip" data-value="S&amp;OP" aria-pressed="false">S&amp;OP</button>
                  <button type="button" class="cf-chip" data-value="Supply planning" aria-pressed="false">Supply planning</button>
                  <button type="button" class="cf-chip" data-value="Other" aria-pressed="false">Other</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">What tools are you using today?</label>
                <div class="cf-chips" data-chips data-field="tools" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Spreadsheet-based planning" aria-pressed="false">Spreadsheet-based</button>
                  <button type="button" class="cf-chip" data-value="ERP planning tools" aria-pressed="false">ERP planning tools</button>
                  <button type="button" class="cf-chip" data-value="SAP IBP" aria-pressed="false">SAP IBP</button>
                  <button type="button" class="cf-chip" data-value="Other planning software" aria-pressed="false">Other planning software</button>
                  <button type="button" class="cf-chip" data-value="Combination of tools" aria-pressed="false">Combination of tools</button>
                  <button type="button" class="cf-chip" data-value="Other" aria-pressed="false">Other</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">How would you describe your current planning maturity?</label>
                <div class="cf-chips" data-chips data-field="maturity" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Still heavily manual" aria-pressed="false">Still heavily manual</button>
                  <button type="button" class="cf-chip" data-value="Partly structured but fragmented" aria-pressed="false">Partly structured but fragmented</button>
                  <button type="button" class="cf-chip" data-value="Established, improving visibility" aria-pressed="false">Established, improving visibility</button>
                  <button type="button" class="cf-chip" data-value="Advanced, want stronger capabilities" aria-pressed="false">Advanced, want stronger capabilities</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div class="cf-foot"><button type="button" class="btn btn-secondary" data-back>Back</button><button type="button" class="btn btn-primary" data-next>Continue</button></div>
            </div>

            <!-- STEP 3 -->
            <div class="cf-step" data-step>
              <div class="cf-step-title">Your main challenge</div>
              <div class="cf-step-sub">What is getting in the way of planning today? Choose any that apply.</div>
              <div data-row>
                <label class="cf-label">Where does it get difficult?</label>
                <div class="cf-chips" data-chips data-multi data-field="challenges" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Forecasts are difficult to trust" aria-pressed="false">Forecasts difficult to trust</button>
                  <button type="button" class="cf-chip" data-value="Demand drivers are not clear" aria-pressed="false">Demand drivers not clear</button>
                  <button type="button" class="cf-chip" data-value="Reviews take too long" aria-pressed="false">Reviews take too long</button>
                  <button type="button" class="cf-chip" data-value="Disconnected tools" aria-pressed="false">Planning across disconnected tools</button>
                  <button type="button" class="cf-chip" data-value="Inventory decisions are reactive" aria-pressed="false">Inventory decisions reactive</button>
                  <button type="button" class="cf-chip" data-value="Scenario testing is difficult" aria-pressed="false">Scenario testing difficult</button>
                  <button type="button" class="cf-chip" data-value="Too much manual analysis" aria-pressed="false">Too much manual analysis</button>
                  <button type="button" class="cf-chip" data-value="Teams not aligned on the plan" aria-pressed="false">Teams not aligned</button>
                  <button type="button" class="cf-chip" data-value="Other" aria-pressed="false">Other</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">What would you like Haidi to help you improve?</label>
                <textarea class="cf-area" data-field="improve" placeholder="In your own words — the outcome that would matter most."></textarea>
              </div>
              <div class="cf-foot"><button type="button" class="btn btn-secondary" data-back>Back</button><button type="button" class="btn btn-primary" data-next>Continue</button></div>
            </div>

            <!-- STEP 4 -->
            <div class="cf-step" data-step>
              <div class="cf-step-title">Data readiness</div>
              <div class="cf-step-sub">A rough sense of what data is available — no exact answers needed.</div>
              <div data-row>
                <label class="cf-label">Do you have historical sales or demand data available?</label>
                <div class="cf-chips" data-chips data-field="historical" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Yes" aria-pressed="false">Yes</button>
                  <button type="button" class="cf-chip" data-value="Partly" aria-pressed="false">Partly</button>
                  <button type="button" class="cf-chip" data-value="Not sure yet" aria-pressed="false">Not sure yet</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">Do you have master data available?</label>
                <div class="cf-chips" data-chips data-field="masterData" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Yes" aria-pressed="false">Yes</button>
                  <button type="button" class="cf-chip" data-value="Partly" aria-pressed="false">Partly</button>
                  <button type="button" class="cf-chip" data-value="Not sure yet" aria-pressed="false">Not sure yet</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">Are there useful planning drivers available?</label>
                <div class="cf-chips" data-chips data-field="drivers" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Yes" aria-pressed="false">Yes</button>
                  <button type="button" class="cf-chip" data-value="Partly" aria-pressed="false">Partly</button>
                  <button type="button" class="cf-chip" data-value="Not sure yet" aria-pressed="false">Not sure yet</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div data-row>
                <label class="cf-label">When are you looking to start?</label>
                <div class="cf-chips" data-chips data-field="timing" data-required="chips">
                  <button type="button" class="cf-chip" data-value="Exploring options" aria-pressed="false">Exploring options</button>
                  <button type="button" class="cf-chip" data-value="Within three months" aria-pressed="false">Within three months</button>
                  <button type="button" class="cf-chip" data-value="Within six months" aria-pressed="false">Within six months</button>
                  <button type="button" class="cf-chip" data-value="Not sure yet" aria-pressed="false">Not sure yet</button>
                </div>
                <span class="cf-msg" data-msg></span>
              </div>
              <div class="cf-foot"><button type="button" class="btn btn-secondary" data-back>Back</button><button type="button" class="btn btn-primary" data-next>Review</button></div>
            </div>

            <!-- STEP 5 · SUMMARY -->
            <div class="cf-step" data-step data-summary-step>
              <div class="cf-step-title">We have what we need to understand the starting point.</div>
              <div class="cf-step-sub">Our team will review your answers and come back with the most relevant next step — a tailored demo, a focused discussion, or a relevant case example.</div>
              <div class="cf-summary" data-summary></div>
              <div class="cf-foot"><button type="button" class="btn btn-secondary" data-back>Back</button><button type="button" class="btn btn-primary" data-submit>Prepare my next step</button></div>
            </div>

          </div>
        </div>

        <!-- DONE -->
        <div class="cf-done" data-done>
          <div class="cf-check"><svg viewBox="0 0 24 24" fill="none" width="28" height="28"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <h2>Thank you<span data-greet></span> — we have what we need.</h2>
          <p>Our team will review your planning context and come back with the most useful next step, whether that is a tailored demo, a focused discussion, or a relevant case example.</p>
          <p style="color:var(--text-muted);font-size:13px;margin-top:14px">You can close this page — there is nothing else to do right now.</p>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="ct-side">
        <div class="side-card">
          <span class="ap-flag"><span></span> Built with planning expertise</span>
          <h3 style="margin-bottom:14px">Developed by IBP Ready</h3>
          <ul class="side-list">
            <li><svg viewBox="0 0 24 24" fill="none"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Switzerland-based supply chain consulting company</li>
            <li><svg viewBox="0 0 24 24" fill="none"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> 60+ years of combined planning experience</li>
            <li><svg viewBox="0 0 24 24" fill="none"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Experience with global enterprise planning environments</li>
            <li><svg viewBox="0 0 24 24" fill="none"><path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Built around practical planning workflows</li>
          </ul>
        </div>
        <div class="side-card side-contact">
          <h3>Prefer to reach us directly?</h3>
          <a href="mailto:hello@haidi.io"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.7"/></svg> hello@haidi.io</a>
