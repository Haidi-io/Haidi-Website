---
import ProductPage from '../components/ProductPage.astro';

const modules = [
  {
    eyebrow: 'Forecast Lab',
    heading: 'Run forecasting experiments <span class="accent">with clarity.</span>',
    desc: 'Experiment-driven by design — test forecasting approaches side by side and select results your team can understand and trust.',
    list: [
      'Historical demand alongside each experiment',
      'Multiple forecast experiments, compared',
      'Accuracy and confidence indicators',
      'A clear reason a forecast is preferred',
    ],
    mock: 'experiments',
    url: 'app.haidi.io / forecast-lab',
  },
  {
    eyebrow: 'Demand Drivers',
    heading: 'Understand what is <span class="accent">moving the forecast.</span>',
    desc: 'Bring meaningful demand signals into the forecast to understand what is actually driving demand — the basis for both demand sensing and demand steering.',
    list: [
      'A ranked list of drivers with impact indicators',
      'Seasonal patterns and commercial activity',
      'Correlation between signals and demand',
      'Forecast movement linked to a selected driver',
    ],
    mock: 'drivers',
    url: 'app.haidi.io / drivers',
    flip: true,
  },
  {
    eyebrow: 'Scenario Testing',
    heading: 'Test decisions before they <span class="accent">become commitments.</span>',
    desc: 'Test assumptions, compare outcomes, and understand the consequences of planning decisions before acting on them.',
    list: [
      'Compare a baseline with alternative scenarios',
      'Watch forecast lines change as assumptions change',
      'Duplicate scenarios and adjust planning variables',
      'See a clear impact summary for each outcome',
    ],
    mock: 'scenario',
    url: 'app.haidi.io / scenarios',
  },
  {
    eyebrow: 'Demand Review',
    heading: 'Challenge the forecast, <span class="accent">then decide.</span>',
    desc: 'Bring the team together to challenge the forecast, align stakeholders, and document decisions in one place.',
    list: [
      'Forecast versus actual, side by side',
      'Exception flags for what needs attention',
      'Assumptions, overrides, and planner comments',
      'Decision status and ownership',
    ],
    mock: 'review',
    url: 'app.haidi.io / demand-review',
    flip: true,
  },
];
---

<ProductPage
  eyebrow="Demand Planning"
  title="Haidi — Demand Planning"
  description="Experiment-driven demand planning for planners and data scientists — Forecast Lab, demand drivers, scenario testing, and structured demand review."
  canonical="https://haidi.io/demand-planning"
  headline="Experiment-driven demand planning, <span class='accent'>for planners and data scientists.</span>"
  sub="Run forecasting experiments, bring in the drivers moving demand, pressure-test the choices with scenarios, and challenge the forecast together — one connected module for demand planners and data scientists alike."
  modules={modules}
  finalHeading="Demand planning your team can <span class='accent'>explain.</span>"
  finalSub="See Haidi run on your own demand data — set up in under 2 hours, no specialists required."
/>
