---
import ProductPage from '../components/ProductPage.astro';

const modules = [
  {
    eyebrow: 'HaidiGen',
    heading: 'Ask questions. Understand the plan. <span class="accent">Move forward.</span>',
    desc: 'A planning assistant connected across your foundation, demand, and inventory views – so answers reference the actual plan, not generic responses. It helps planners and data scientists work through decisions faster; it does not replace them.',
    chips: [
      'What changed in this forecast?',
      'Which products need review?',
      'What is driving this exception?',
      'Compare the baseline with this scenario',
      'Summarise the main planning risks',
    ],
    mock: 'chat',
    url: 'app.haidi.io / haidi-gen',
    draw: true,
  },
];
---

<ProductPage
  eyebrow="HaidiGen"
  title="Haidi – HaidiGen"
  description="A planning assistant connected across your foundation, demand, and inventory views – so answers reference the actual plan, not generic responses."
  canonical="https://haidi.io/haidi-gen"
  headline="Ask questions. Understand the plan. <span class='accent'>Move forward.</span>"
  sub="A planning assistant connected across your foundation, demand, and inventory views – so answers reference the actual plan, not generic responses."
  modules={modules}
  finalHeading="A planning assistant that <span class='accent'>knows your plan.</span>"
  finalSub="See HaidiGen answer against your own planning context – set up in under 2 hours, no specialists required."
/>
