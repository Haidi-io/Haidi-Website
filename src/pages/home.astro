---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
import HomeHero from '../components/home/HomeHero.astro';
import HomeValue from '../components/home/HomeValue.astro';
import HomeInsideProduct from '../components/home/HomeInsideProduct.astro';
import HomeConfigure from '../components/home/HomeConfigure.astro';
import HomeHowItWorks from '../components/home/HomeHowItWorks.astro';
import HomeAbout from '../components/home/HomeAbout.astro';
import HomeLaunch from '../components/home/HomeLaunch.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Haidi',
  applicationCategory: 'BusinessApplication',
  description: 'Supply chain planning platform',
  provider: {
    '@type': 'Organization',
    name: 'IBP Ready',
    address: { '@type': 'PostalAddress', addressCountry: 'CH' },
  },
};
---

<BaseLayout
  title="Haidi – Supply chain planning"
  description="Haidi brings demand, inventory, and supply planning into one workspace – decisions your team can explain, with full transparency into the reasoning behind them."
  canonical="https://haidi.io/home"
  ogTitle="Haidi – Supply chain planning"
  ogDescription="Planning that gives your team a reason to trust the forecast. Built by supply chain practitioners."
  ogUrl="https://haidi.io/home"
  screenLabel="Home"
  jsonLd={jsonLd}
  heroVariants
  scripts={['haidi-site.js', 'haidi-tweaks.js']}
>
  <div class="home-flow">
    <HomeHero />
    <HomeValue />
    <HomeInsideProduct />
    <HomeConfigure />
    <HomeHowItWorks />
    <HomeAbout />
    <HomeLaunch />
  </div>
</BaseLayout>
